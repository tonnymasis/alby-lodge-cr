# Google Maps API Configuration
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Ejemplo de dónde obtener tu API key:
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita la API de Google Maps JavaScript
# 4. Crea credenciales (API Key)
# 5. Opcionalmente, restringe la API key a tu dominio
# 6. Reemplaza "your_google_maps_api_key_here" con tu API key real

# Otras configuraciones del proyecto
VITE_APP_NAME=Alby Lodge
VITE_APP_VERSION=1.0.0